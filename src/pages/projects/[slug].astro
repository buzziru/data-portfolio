---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectThumb from '../../components/ProjectThumb';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const STATUS_LABEL: Record<string, string> = {
  completed: 'Completed',
  progress: 'In Progress',
  planned: 'Planned',
};
---

<BaseLayout title={`${d.title} — Research Notebook`} description={d.summary}>
  <main class="detail-main">
    <div class="wrap">
      <a class="detail-back" href="/#projects">← 프로젝트 목록으로</a>

      <div class="detail-head-grid">
        <div class="detail-head-left">
          <div class="detail-kicker">CASE {String(d.order).padStart(2, '0')} · {d.domain}</div>
          <h1 class="detail-title">{d.title}</h1>
          <span class={`status-pill status-${d.status} mono`} style="position:static;display:inline-block;margin-bottom:16px;">{STATUS_LABEL[d.status]}</span>
          <p class="detail-summary">{d.summary}</p>
          <p class="detail-metric mono">{d.keyMetric}</p>

          <dl class="detail-meta">
            {d.date && <div><dt>Date</dt><dd>{d.date}</dd></div>}
            <div><dt>Domain</dt><dd>{d.domain}</dd></div>
            <div><dt>Role</dt><dd>{d.role}</dd></div>
            <div><dt>Methods</dt><dd>{d.methods.join(' · ')}</dd></div>
            <div><dt>Tools</dt><dd>{d.tools.join(', ')}</dd></div>
          </dl>

          {(d.github || d.demo) && (
            <div class="detail-actions">
              {d.github && <a class="btn btn-ghost" href={d.github} target="_blank" rel="noopener">GitHub ↗</a>}
              {d.demo && <a class="btn btn-primary" href={d.demo} target="_blank" rel="noopener">Live Demo ↗</a>}
            </div>
          )}
        </div>
        <div class="detail-thumb-lg">
          {d.image
            ? <img src={d.image} alt={`${d.title} 데모 대시보드`} loading="lazy" />
            : <ProjectThumb thumb={d.thumb} />}
        </div>
      </div>

      <article class="detail-body">
        <Content />
      </article>

      {d.demo && (
        <section class="detail-demo">
          <div class="detail-demo-head">
            <span class="detail-demo-kicker mono">LIVE DEMO</span>
            <a class="detail-demo-ext mono" href={d.demo} target="_blank" rel="noopener">새 탭에서 열기 ↗</a>
          </div>
          <p class="detail-demo-note">{d.demoNote ?? '브라우저 안에서 ONNX 모델이 직접 추론합니다 — 서버 없음. 고객 정보를 입력하면 이탈 확률을 즉시 예측합니다.'}</p>
          <div class="detail-demo-frame">
            <iframe id="demo-frame" src={d.demo} title={`${d.title} 인터랙티브 데모`} loading="lazy"></iframe>
          </div>
        </section>
      )}
    </div>
  </main>

  {d.demo && (
    <script type="module" define:vars={{ demoOrigin: new URL(d.demo).origin }}>
      // 데모(iframe)가 보내는 콘텐츠 높이에 맞춰 iframe 높이를 동기화 (내부 스크롤 제거)
      window.addEventListener('message', (e) => {
        if (e.origin !== demoOrigin) return;
        const data = e.data;
        if (data && typeof data.type === 'string' && data.type.endsWith('-demo-height') && typeof data.height === 'number') {
          const frame = document.getElementById('demo-frame');
          if (frame) frame.style.height = Math.ceil(data.height) + 'px';
        }
      });
    </script>
  )}
</BaseLayout>
